REACT_APP_SUPABASE_URL=http://127.0.0.1:54321
REACT_APP_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Optional local demo login. Use only anon/public client credentials in the mobile app.
REACT_APP_SUPABASE_DEMO_EMAIL=adopter@petpal.local
REACT_APP_SUPABASE_DEMO_PASSWORD=petpal-demo-password

# Optional: stored with push token registrations for debugging/version tracking.
REACT_APP_VERSION=local
